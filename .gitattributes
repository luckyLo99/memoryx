# Auto detect text files and normalize line endings
* text=auto

# Python source
*.py text diff=python

# Markdown
*.md text

# YAML/JSON
*.yml text
*.yaml text
*.json text

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Batch files
*.bat text eol=crlf

# Git files
.gitattributes text
.gitignore text

# Binary files - don't touch
*.png binary
*.jpg binary
*.ico binary
*.db binary
*.sqlite3 binary
