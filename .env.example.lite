# MemoryX Lite Profile (no embedding, no vector)
MEMORYX_LOG_LEVEL=INFO
MEMORYX_HOME=./data
MEMORYX_QUEUE_SIZE=256
MEMORYX_WORKERS=2
MEMORYX_HANDLER_TIMEOUT_SECONDS=5
MEMORYX_RETRY_ATTEMPTS=3
MEMORYX_RETRY_BASE_DELAY=0.2
MEMORYX_RETRY_MAX_DELAY=2.0
MEMORYX_DRAIN_TIMEOUT_SECONDS=10
MEMORYX_QUEUE_WARNING_THRESHOLD=0.8
MEMORYX_EMBEDDING_ENABLED=false
MEMORYX_VECTOR_STORE=lite
